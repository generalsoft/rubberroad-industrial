---
export interface Props { lang: string; dir: string; }
const { lang } = Astro.props;
const { translations } = await import("../i18n/translations");
const t = translations[lang];
const footer = t.footer;
const year = new Date().getFullYear();
---

<footer style="background:var(--primary);color:rgba(255,255,255,0.8);padding:60px 0 30px;">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:40px;margin-bottom:40px;">
      <div>
        <h3 style="color:var(--gold);font-size:1.3rem;margin-bottom:20px;"><i class="fas fa-road"></i> Rubber Road</h3>
        <p style="line-height:1.8;">{t.hero.subtitle}</p>
      </div>
      <div>
        <h3 style="color:white;margin-bottom:20px;">{t.contact.title}</h3>
        {Object.values(t.contact.info).map(info => <p style="margin-bottom:10px;"><i class="fas fa-circle" style="font-size:0.4rem;color:var(--gold);margin-right:8px;"></i>{info}</p>)}
      </div>
      <div>
        <h3 style="color:white;margin-bottom:20px;">{lang==='en'?'Quick Links':'روابط سريعة'}</h3>
        {Object.entries(t.nav).map(([key, value]) => <p style="margin-bottom:10px;"><a href={`/${lang}/${key==='home'?'':key}/`} style="color:rgba(255,255,255,0.8);"><i class="fas fa-chevron-right" style="margin-right:8px;font-size:0.8rem;"></i>{value}</a></p>)}
      </div>
    </div>
    <hr style="border-color:rgba(255,255,255,0.1);margin-bottom:30px;" />
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:15px;">
      <p>&copy; {year} Rubber Road Industrial. {footer.rights}.</p>
      <div style="display:flex;gap:20px;">
        <a href="#" style="color:rgba(255,255,255,0.8);">{footer.privacy}</a>
        <a href="#" style="color:rgba(255,255,255,0.8);">{footer.terms}</a>
      </div>
    </div>
  </div>
</footer>

---
export async function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "ar" } }];
}

import Layout from "../../layouts/Layout.astro";

const lang = Astro.params.lang || "en";
const dir = lang === "ar" ? "rtl" : "ltr";
const { translations } = await import("../../i18n/translations");
const t = translations[lang];
const isAr = lang === "ar";
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Rubber Road Industrial — Engineered Rubber Solutions, UAE"
  lang={lang}
  dir={dir}
>
  <div class="circuit-bg"></div>

<nav id="nav">
    <div></div>
    <ul id="nav-links">
      <li><a href="#story" onclick="closeMenu()">{t.nav.story}</a></li>
      <li><a href="#material" onclick="closeMenu()">{t.nav.material}</a></li>
      <li><a href="#industries" onclick="closeMenu()">{t.nav.industries}</a></li>
      <li><a href="#products" onclick="closeMenu()">{t.nav.products}</a></li>
      <li><a href="#certs" onclick="closeMenu()">{t.nav.trust}</a></li>
      <li><a href="#contact" class="nav-cta" onclick="closeMenu()">{t.nav.getQuote}</a></li>
      <li><a href={`/${lang === 'en' ? 'ar' : 'en'}/`} style="font-size:0.72rem;border:1px solid var(--green);padding:6px 12px;color:var(--green)!important;">{lang === 'en' ? 'العربية' : 'English'}</a></li>
    </ul>
    <!-- Hamburger button -->
    <button class="burger" id="burger-btn" style="
      display:none;
      background:none;
      border:none;
      cursor:pointer;
      flex-direction:column;
      gap:5px;
      padding:5px;
    " onclick="toggleMenu()">
      <span style="display:block;width:24px;height:2px;background:var(--green);transition:all .3s;"></span>
      <span style="display:block;width:24px;height:2px;background:var(--green);transition:all .3s;"></span>
      <span style="display:block;width:24px;height:2px;background:var(--green);transition:all .3s;"></span>
    </button>
</nav>

<!-- HERO -->
<header class="hero">
    <div class="hero-grid" style="align-items:start;">
      {isAr ? (
        <!-- Arabic: Logo first (left), then text (right) -->
        <>
          <!-- Logo -->
          <div style="display:flex;align-items:flex-start;justify-content:center;padding-top:80px;">
            <div style="width:100%;max-width:280px;opacity:0.9;">
              <img src={base + "/images/logo/rubber_road_3d_logo.png"} alt="Rubber Road Industrial" style="width:100%;height:auto;" />
            </div>
          </div>
          <!-- Text -->
          <div>
            <div class="eyebrow">{t.hero.eyebrow}</div>
            <h1 style="margin-top:18px;">
              <span class="outline">{t.hero.line1}</span><br>
              <span class="accent">{t.hero.line2}</span><br>
              {t.hero.line3}
            </h1>
            <p class="hero-sub">{t.hero.subtitle}</p>
            <div class="hero-cta">
              <a href="#products" class="btn btn-solid">{t.hero.viewProducts}</a>
              <a href="#contact" class="btn btn-ghost">{t.hero.requestQuote}</a>
            </div>
          </div>
        </>
      ) : (
        <!-- English: Text first (left), then logo (right) -->
        <>
          <!-- Text -->
          <div>
            <div class="eyebrow">{t.hero.eyebrow}</div>
            <h1 style="margin-top:18px;">
              <span class="outline">{t.hero.line1}</span><br>
              <span class="accent">{t.hero.line2}</span><br>
              {t.hero.line3}
            </h1>
            <p class="hero-sub">{t.hero.subtitle}</p>
            <div class="hero-cta">
              <a href="#products" class="btn btn-solid">{t.hero.viewProducts}</a>
              <a href="#contact" class="btn btn-ghost">{t.hero.requestQuote}</a>
            </div>
          </div>
      <!-- Logo with 3D rotation -->
<div style={`
  display:flex;
  align-items:flex-start;
  justify-content:center;
  padding-top:80px;
  ${isAr ? 'order: 3;' : ''}
`}>
  <div style="width:100%;max-width:280px;opacity:0.9;">
    <img 
      src={base + "/images/logo/rubber_road_3d_logo.png"} 
      alt="Rubber Road Industrial" 
      style="
        width:100%;
        height:auto;
        animation: rotateLogo 6s ease-in-out infinite;
        transform-style: preserve-3d;
        perspective: 1000px;
      " 
    />
  </div>
</div>
        </>
      )}
    </div>
    
    <!-- Meta stats below -->
    <div style="max-width:1280px;margin:0 auto;width:100%;padding:0 40px;margin-top:40px;">
      <div class="hero-meta" style="border-left:none;padding-left:0;border-top:1px solid var(--line);padding-top:20px;flex-direction:row;flex-wrap:wrap;display:flex;gap:40px;">
        <div><b>1952</b>{t.hero.meta1}</div>
        <div><b>03</b>{t.hero.meta2}</div>
        <div><b>8+</b>{t.hero.meta3}</div>
      </div>
    </div>
    
    <div class="scroll-cue"><div class="line"></div>{isAr ? 'اسفل' : 'Scroll'}</div>
</header>

  <!-- MARQUEE -->
  <div class="marquee-strip">
    <span>
      NR &nbsp;<b>•</b>&nbsp; SI &nbsp;<b>•</b>&nbsp; EPDM &nbsp;<b>•</b>&nbsp;
      IIR &nbsp;<b>•</b>&nbsp; NBR &nbsp;<b>•</b>&nbsp; SBR &nbsp;<b>•</b>&nbsp;
      PBR &nbsp;<b>•</b>&nbsp; PU &nbsp;<b>•</b>&nbsp; FKM &nbsp;<b>•</b>&nbsp;
      CUSTOM ENGINEERED COMPOUNDS &nbsp;<b>•</b>&nbsp; NR &nbsp;<b>•</b>&nbsp;
      SI &nbsp;<b>•</b>&nbsp; EPDM &nbsp;<b>•</b>&nbsp; IIR &nbsp;<b>•</b>&nbsp;
      NBR &nbsp;<b>•</b>&nbsp; SBR &nbsp;<b>•</b>&nbsp; PBR &nbsp;<b>•</b>&nbsp;
      PU &nbsp;<b>•</b>&nbsp; FKM &nbsp;<b>•</b>&nbsp; CUSTOM ENGINEERED
      COMPOUNDS &nbsp;<b>•</b>&nbsp;
    </span>
  </div>

  <!-- STORY -->
  <section class="story" id="story">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>{t.story.title}</h2>
        <p>{t.story.subtitle}</p>
      </div>
      <div class="story-grid">
        <div class="story-text reveal">
          <p>{t.story.p1}</p>
          <p>{t.story.p2}</p>
          <p>{t.story.p3}</p>
          <div class="quote">
            {t.story.quote}
            <cite>{t.story.quoteCite}</cite>
          </div>
        </div>
        <div class="timeline reveal">
          {
            t.story.timeline.map((item) => (
              <div class="t-item">
                <div class="yr">{item.year}</div>
                <div class="ttl">{item.title}</div>
                <div class="dsc">{item.desc}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- MATERIAL / PROCESS -->
  <section id="material">
    <div class="wrap">
      <div class="material-intro reveal">
        <div>
          <div class="eyebrow">{t.material.eyebrow}</div>
          <h2 style="font-size:clamp(2rem,4vw,3.2rem);margin-top:14px;">
            {t.material.title}
          </h2>
        </div>
        <div>
          <p>{t.material.p1}</p>
          <p>{t.material.p2}</p>
        </div>
      </div>
      <div class="props reveal">
        {
          t.material.props.map((prop) => (
            <div class="prop">
              <div class="ic">{prop.name}</div>
              <div class="lb">{prop.desc}</div>
            </div>
          ))
        }
      </div>
      <div style="margin-top:110px;" class="reveal">
        <div class="section-head" style="margin-bottom:30px;">
          <h2 style="font-size:clamp(2rem,4vw,3.2rem);">
            {t.material.processTitle}
          </h2>
          <p>{t.material.processSub}</p>
        </div>
        <div class="process-belt">
          {
            t.material.process.map((stage, index) => (
              <div class="p-stage" data-n={String(index + 1).padStart(2, "0")}>
                <h4>{stage.name}</h4>
                <p>{stage.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="industries" id="industries">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>{t.industries.title}</h2>
        <p>{t.industries.subtitle}</p>
      </div>
      <div class="ind-grid reveal">
        {
          t.industries.items.map((item, index) => (
            <div class="ind-card">
              <span class="num">{String(index + 1).padStart(2, "0")}</span>
              <h4>{item.name}</h4>
              <p>{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>{t.products.title}</h2>
        <p>{t.products.subtitle}</p>
      </div>
      <div class="prod-grid reveal">
        {
          t.products.items.map((product, index) => (
            <div class="prod-card">
              <div class={`prod-icon ${product.iconClass}`} />
              <h4>{product.name}</h4>
              <div class="tag">{product.tag}</div>
              <p>{product.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CERTS / CLIENTS -->
  <section class="certs" id="certs">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>{t.certs.title}</h2>
        <p>{t.certs.subtitle}</p>
      </div>
      <div class="cert-grid reveal">
        {
          t.certs.certifications.map((cert) => (
            <div class="cert-card">
              <div class="iso">{cert.number}</div>
              <div class="ct">
                <b>{cert.name}</b>
                {cert.standard}
              </div>
            </div>
          ))
        }
      </div>
      <div class="eyebrow reveal" style="margin-bottom:24px;">
        {t.certs.clientsTitle}
      </div>
      <div class="clients-row reveal">
        {t.certs.clients.map((client) => <div class="client">{client}</div>)}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="wrap">
      <div class="contact-grid">
        <div class="reveal">
          <div class="eyebrow">{t.contact.eyebrow}</div>
          <h2>{t.contact.title}</h2>
          <p>{t.contact.subtitle}</p>
          <div class="contact-list">
            {
              t.contact.details.map((detail) => (
                <div class="row">
                  <span>{detail.label}</span>
                  {detail.href ? (
                    <a href={detail.href}>{detail.value}</a>
                  ) : (
                    <span>{detail.value}</span>
                  )}
                </div>
              ))
            }
          </div>
        </div>
        <div class="panel-box reveal">
          <h3>{t.contact.panelTitle}</h3>
          <p>{t.contact.panelText}</p>
          <a
            href={t.contact.emailLink}
            class="btn btn-solid"
            style="width:100%;justify-content:center;">{t.contact.emailBtn}</a
          >
          <a
            href={t.contact.callLink}
            class="btn btn-ghost"
            style="width:100%;justify-content:center;margin-top:14px;"
            >{t.contact.callBtn}</a
          >
        </div>
      </div>
    </div>
  </section>

    <!-- Floating WhatsApp Button -->
  <a 
    href="https://wa.me/971528099319" 
    target="_blank" 
    rel="noopener noreferrer"
    style="
      position:fixed;
      bottom:24px;
      right:24px;
      z-index:1000;
      width:56px;
      height:56px;
      background:#25D366;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 4px 15px rgba(37,211,102,0.4);
      transition:all .3s ease;
      cursor:pointer;
    "
    onmouseover="this.style.transform='scale(1.1)';this.style.boxShadow='0 6px 25px rgba(37,211,102,0.6)'"
    onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 15px rgba(37,211,102,0.4)'"
    aria-label="Contact via WhatsApp"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Vertical QR Code Strip -->
  <div style={`
    position:fixed;
    ${isAr ? 'left' : 'right'}:24px;
    top:50%;
    transform:translateY(-50%);
    z-index:1000;
    display:flex;
    flex-direction:column;
    gap:12px;
    background:rgba(27,29,26,0.85);
    backdrop-filter:blur(5px);
    border:1px solid var(--line);
    border-radius:8px;
    padding:12px 8px;
  `}>
    <a href={base + "/images/qr/website.png"} target="_blank" rel="noopener noreferrer" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-align:center;">
      <img src={base + "/images/qr/website.png"} alt="Website QR" style="width:48px;height:48px;border-radius:3px;" />
      <span style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:var(--green);text-transform:uppercase;letter-spacing:.04em;">{isAr ? 'الموقع' : 'Website'}</span>
    </a>
    <div style="width:100%;height:1px;background:var(--line);"></div>
    <a href={base + "/images/qr/Contact.png"} target="_blank" rel="noopener noreferrer" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-align:center;">
      <img src={base + "/images/qr/Contact.png"} alt="Contact QR" style="width:48px;height:48px;border-radius:3px;" />
      <span style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:var(--green);text-transform:uppercase;letter-spacing:.04em;">{isAr ? 'اتصال' : 'Contact'}</span>
    </a>
    <div style="width:100%;height:1px;background:var(--line);"></div>
    <a href={base + "/images/qr/Location.png"} target="_blank" rel="noopener noreferrer" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-align:center;">
      <img src={base + "/images/qr/Location.png"} alt="Location QR" style="width:48px;height:48px;border-radius:3px;" />
      <span style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:var(--green);text-transform:uppercase;letter-spacing:.04em;">{isAr ? 'الموقع' : 'Location'}</span>
    </a>
  </div>

  <footer>
    <div
      class="wrap"
      style="display:flex;justify-content:space-between;width:100%;flex-wrap:wrap;gap:12px;"
    >
      <span>© <span id="yr"></span> {t.footer.left}</span>
      <span>{t.footer.right}</span>
      <span style="font-size:0.65rem;opacity:0.6;">
        {isAr ? 'طور بواسطة' : 'Developed by'}{' '}
        <a
          href={isAr ? 'https://generalsoft.ae/ar/' : 'https://generalsoft.ae/en/'}
          target="_blank"
          rel="noopener noreferrer"
          style="color:var(--green);text-decoration:none;"
          onmouseover="this.style.textDecoration='underline'"
          onmouseout="this.style.textDecoration='none'"
        >Generalsoft</a>
      </span>
    </div>
  </footer>
</Layout>
